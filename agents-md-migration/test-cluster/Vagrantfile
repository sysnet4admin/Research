# -*- mode: ruby -*-
# vi: set ft=ruby :

## configuration variables ##
# max number of worker nodes (this study needs only ONE schedulable node)
N = 1
# each of components to install
k8s_V    = '1.36.2-2.1'                   # Kubernetes (AIOps는 1.36.0 → 이 연구는 최신 1.36 패치로 상향. 1.36.2 빌드 리비전은 -2.1)
ctrd_V   = '2.2.3-1~ubuntu.24.04~noble'  # Containerd
## /configuration variables ##
#
# 이 클러스터는 AIOps-Agent-Benchmark 클러스터와 완전히 격리된다:
#   - 서브넷    192.168.2.0/24   (AIOps는 192.168.1.0/24)
#   - VBox 그룹 /agents-md-migration
#   - VM 접미사 -agentsmd
#   - ssh 포워딩 60160/60161
# 동시에 떠 있어도 IP·이름이 겹치지 않는다.

Vagrant.configure("2") do |config|

  #====================#
  # Control-Plane Node #
  #====================#

    config.vm.define "cp-k8s-#{k8s_V[0..5]}" do |cfg|
      cfg.vm.box = "sysnet4admin/Ubuntu-k8s"
      cfg.vm.provider "virtualbox" do |vb|
        vb.name = "cp-k8s-#{k8s_V[0..5]}-agentsmd"
        vb.cpus = 2
        vb.memory = 4096
        vb.customize ["modifyvm", :id, "--groups", "/agents-md-migration"]
      end
      cfg.vm.host_name = "cp-k8s"
      cfg.vm.network "private_network", ip: "192.168.2.10"
      cfg.vm.network "forwarded_port", guest: 22, host: 60160, auto_correct: true, id: "ssh"
      cfg.vm.synced_folder "../data", "/vagrant", disabled: true
      cfg.vm.provision "shell", path: "k8s_env_build.sh", args: [ N, k8s_V[0..3] ]
      cfg.vm.provision "shell", path: "k8s_pkg_cfg.sh", args: [ k8s_V, ctrd_V, "CP"]
      cfg.vm.provision "shell", path: "controlplane_node.sh"
      cfg.vm.provision "shell", path: "extra_k8s_pkgs.sh"
    end

  #==============#
  # Worker Nodes #
  #==============#

  (1..N).each do |i|
    config.vm.define "w#{i}-k8s-#{k8s_V[0..5]}" do |cfg|
      cfg.vm.box = "sysnet4admin/Ubuntu-k8s"
      cfg.vm.provider "virtualbox" do |vb|
        vb.name = "w#{i}-k8s-#{k8s_V[0..5]}-agentsmd"
        vb.cpus = 2
        vb.memory = 4096
        vb.customize ["modifyvm", :id, "--groups", "/agents-md-migration"]
      end
      cfg.vm.host_name = "w#{i}-k8s"
      cfg.vm.network "private_network", ip: "192.168.2.1#{i}"
      cfg.vm.network "forwarded_port", guest: 22, host: "6016#{i}", auto_correct: true, id: "ssh"
      cfg.vm.synced_folder "../data", "/vagrant", disabled: true
      cfg.vm.provision "shell", path: "k8s_env_build.sh", args: [ N, k8s_V[0..3] ]
      cfg.vm.provision "shell", path: "k8s_pkg_cfg.sh", args: [ k8s_V, ctrd_V, "W" ]
      cfg.vm.provision "shell", path: "worker_nodes.sh"
    end
  end

end
