# scoring 파이프라인 생성 산출물 (재생성 가능)
results/aggregated.json
results/scores.json
results/aggregated-v3-fresh.json
results/aggregated-ops.json
results/aggregated-kong-expr.json
results/aggregated-kgw-ba.json
# 역할 분리: GitHub은 마크다운 정본만 보유, HTML 렌더는 블로그/로컬 전용.
# README_tables{,_ko}.md = GitHub 마크다운 렌더(정본, 커밋 대상).
# report{,_ko}.html = 블로그/로컬용 인터랙티브(파이프라인이 생성하나 커밋 안 함,
#   GitHub은 HTML을 소스로만 보여줘 의미 없음). 재생성: scripts/finalize.sh.
metrics/report.html
metrics/README_tables.md
metrics/*/report.html
metrics/*/report_ko.html
# results/rounds/round-*.json 는 실제 측정 산출이므로 커밋 대상(여기 무시 안 함)
# 합성 검증 데이터(_gen_synthetic.py)는 실제 라운드와 분리, 커밋 제외
results/_synthetic/
# RAW 측정 증거(라운드별, 재생성 가능, AIOps 패턴)
results/raw/
# 아카이브 스냅샷(이력, 커밋 제외)
results/_archive_*
# 런타임 로그(전 디렉토리)
*.log
